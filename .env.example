# ── GC-Mannschaftsverwaltung – Umgebungsvariablen ────────────────────────────
# Kopieren und mit echten Werten füllen:  cp .env.example .env
# Die .env NIEMALS committen!

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=golf
POSTGRES_PASSWORD=SICHERES_PASSWORT_HIER   # in Prod: mind. 20 zufällige Zeichen
POSTGRES_DB=golf_team
POSTGRES_PORT=5432   # nur lokal; in Production kein Port nach außen exponieren!

# ── Adminer ───────────────────────────────────────────────────────────────────
# Nur für lokale Entwicklung! In Production nicht starten.
ADMINER_PORT=8080

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
ENVIRONMENT=development   # production → Swagger-Docs deaktiviert, CORS strikt

# CORS: kommagetrennt; in Production auf deine echte Domain setzen
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
# Prod-Beispiel: ALLOWED_ORIGINS=https://meinclub.de

# Anzahl Uvicorn-Worker (lokal: 1; Production: 2× CPU-Cores empfohlen)
WORKERS=1

# Tenant-Auflösung via JWT team_id Claim (lokal praktisch; in Production: false!)
ALLOW_TEAM_ID_FALLBACK=true

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=SICHERES_PASSWORT_HIER

# ── Backend: Keycloak Integration ────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8180
# Prod-Beispiel: KEYCLOAK_URL=https://auth.meinclub.de
KEYCLOAK_REALM=golf-team-manager
KEYCLOAK_BACKEND_CLIENT_ID=golf-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=replace-me-after-realm-import

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=golf-team-manager
VITE_KEYCLOAK_CLIENT_ID=golf-frontend
